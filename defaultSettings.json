	"vim.visualModeKeyBindingsNonRecursive": [],

	// In Visual mode, start a search with `*` or `#` using the current selection.
	"vim.visualstar": false,

	// Comma-separated list of motion keys that should wrap to next/previous line.
	"vim.whichwrap": "b,s",

	// Searches wrap around the end of the file.
	"vim.wrapscan": true,

	// Specifies whether OmniPascal will create tasks.json and a build script when a project is loaded
	"omnipascal.createBuildScripts": false,

	// Defines the default development environment when no project is loaded
	"omnipascal.defaultDevelopmentEnvironment": "Delphi",

	// Path to the Delphi installation. Example: C:\Program Files (x86)\Embarcadero\Studio\18.0. If this value is empty, OmniPascal will try to find the path by itself.
	"omnipascal.delphiInstallationPath": "",

	// Path to the Free Pascal source files. Example: C:\lazarus\fpc\3.0.0
	"omnipascal.freePascalSourcePath": "",

	// Full path to lazbuild.exe used to build a Lazarus .lpi file.
	"omnipascal.lazbuildPath": "",

	// Full path to MSBuild.exe used to build a Delphi .dproj file. If this value is empty, OmniPascal will try to find the path by itself.
	"omnipascal.msbuildPath": "",

	// Defines the naming convention for the String type used in code completion and hints. (pascalCase => String | camelCase => string)
	"omnipascal.namingConventionString": "pascalCase",

	// Search paths in addition to "omnipascal.delphiInstallationPath"/"omnipascal.freePascalSourcePath" and the current workspace. Separate paths with ';'. TIP: Paths ending with '*' will include all subdirectories recursively!
	"omnipascal.searchPath": "",

	// Defines the locations that will be indexed in background after startup. The index will be used for add-uses-quickfixes when a symbol name can't be resolved and the "Go to Symbol in Workspace" feature.
	"omnipascal.symbolIndex": "workspace",

