	"hg.countBadge": "all",

	// Whether Hg is enabled
	"hg.enabled": true,

	// Ignores the warning when Mercurial is missing.
	"hg.ignoreMissingHgWarning": false,

	// Path to the 'hg' executable (only required if auto-detection fails)
	"hg.path": null,

	// [DEPRECATED: use pushPullScope] Which branch(es) to include in push/pull operations
